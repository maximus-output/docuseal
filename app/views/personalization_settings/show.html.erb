<div class="flex flex-wrap space-y-4 md:flex-nowrap md:space-y-0">
  <%= render 'shared/settings_nav' %>
  <div class="flex-grow max-w-xl mx-auto">
    <p class="text-4xl font-bold mb-4">
      <%= t('email_templates') %>
    </p>
    <div class="space-y-4">
      <%= render 'signature_request_email_form' %>
      <%= render 'documents_copy_email_form' %>
      <%= render 'submitter_completed_email_form' %>
    </div>
    <p class="text-4xl font-bold mb-4 mt-8">
      <%= t('company_logo') %>
    </p>
    <%= render 'logo_form' %>
    <p class="text-4xl font-bold mb-4 mt-8">
      <%= t('submission_form') %>
    </p>
    <div class="space-y-4">
      <%= render 'form_completed_message_form' %>
      <%= render 'form_completed_button_form' %>
      <%= render 'form_policy_links_form' %>
    </div>
    <%= render 'form_customization_settings' %>
    <p class="text-4xl font-bold mb-4 mt-8">
      Stripe Payments
    </p>
    <% stripe_configured = @stripe_config.persisted? && @stripe_config.value&.dig('secret_key').present? %>
    <%= form_with url: settings_personalization_stripe_path, method: :post, html: { class: 'space-y-4' } do |f| %>
      <div class="form-control">
        <%= label_tag :secret_key, 'Stripe Secret Key', class: 'label font-medium' %>
        <%= password_field_tag :secret_key, '',
                               class: 'base-input w-full',
                               placeholder: stripe_configured ? '••••••••••••••••••••••••' : 'sk_live_...',
                               autocomplete: 'off' %>
        <% if stripe_configured %>
          <label class="label"><span class="label-text-alt text-success">✓ Stripe key is configured</span></label>
        <% end %>
      </div>
      <div>
        <%= submit_tag t('save'), class: 'base-button' %>
      </div>
    <% end %>
  </div>
  <div class="w-0 md:w-52"></div>
</div>
